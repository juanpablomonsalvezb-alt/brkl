# Configuración de Email para Notificaciones
# Crea una "App Password" en tu cuenta de Gmail:
# 1. Ve a https://myaccount.google.com/security
# 2. Habilita "2-Step Verification"
# 3. Ve a "App passwords"
# 4. Crea una nueva app password para "Mail"
# 5. Copia la contraseña generada aquí

EMAIL_USER=tu-correo@gmail.com
EMAIL_PASSWORD=tu-app-password-de-16-caracteres
