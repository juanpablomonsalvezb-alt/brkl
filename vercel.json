{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/handler.mjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
