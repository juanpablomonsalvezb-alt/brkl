{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/handler.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler.js"
    },
    {
      "source": "/((?!api/|assets/|images/|videos/|docs/|fonts/|.*\\.\\w+$).*)",
      "destination": "/index.html"
    }
  ]
}
