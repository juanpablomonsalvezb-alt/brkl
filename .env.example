# Database Configuration
# SQLite database file path (defaults to ./taskManagement.db if not set)
# For local development, you can leave this empty or set a custom path
DATABASE_URL=./taskManagement.db

# Session Secret
# Generate a random secret for session encryption
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-here

# Replit Auth Configuration (optional - only needed if using Replit Auth)
# REPL_ID=your-repl-id
# ISSUER_URL=https://replit.com/oidc

# Node Environment
NODE_ENV=development

# Server Port (defaults to 5000)
PORT=5000

# Flow.cl Configuration
# Get these credentials from your Flow.cl account dashboard
# Sandbox: https://sandbox.flow.cl
# Production: https://www.flow.cl
FLOW_API_KEY=your-flow-api-key-here
FLOW_SECRET_KEY=your-flow-secret-key-here
FLOW_API_URL=https://sandbox.flow.cl/api
# Change to https://www.flow.cl/api for production
